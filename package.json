{
  "name": "ezinventory",
  "private": true,
  "version": "0.1.0",
  "description": "EZ Inventory monorepo",
  "author": {
    "name": "Tobias Wälde",
    "email": "tobias.waelde@gmail.com",
    "url": "https://tobiaswaelde.com"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @ezinventory/api dev",
    "dev:app": "pnpm --filter @ezinventory/app dev",
    "openapi:export": "pnpm --filter @ezinventory/api openapi:export",
    "contracts:generate": "pnpm openapi:export && pnpm --filter @ezinventory/contracts generate:types",
    "build": "pnpm -r --workspace-concurrency=1 build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "affected:build": "nx affected -t build",
    "affected:lint": "nx affected -t lint",
    "affected:test": "nx affected -t test",
    "graph": "nx graph",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:screenshots": "pnpm --filter @ezinventory/app docs:screenshots"
  },
  "devDependencies": {
    "@nx/docker": "22.6.5",
    "@nx/eslint": "22.6.5",
    "@nx/nuxt": "22.6.5",
    "@nx/vite": "22.6.5",
    "nx": "22.6.5",
    "vitepress": "1.6.4"
  }
}
