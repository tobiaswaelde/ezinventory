{
  "name": "EZ Inventory",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspaces/ez-inventory",
  "runServices": [
    "workspace",
    "postgres",
    "rustfs"
  ],
  "shutdownAction": "stopCompose",
  "forwardPorts": [
    3000,
    3001,
    5433,
    9000
  ],
  "postCreateCommand": "corepack enable && pnpm install && pnpm --filter @ezinventory/api prisma:generate",
  "postStartCommand": "pnpm --filter @ezinventory/api prisma:db:push",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "prisma.prisma",
        "ms-azuretools.vscode-docker",
        "ms-playwright.playwright"
      ]
    }
  }
}
