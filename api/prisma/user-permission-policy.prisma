model UserPermissionPolicy {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  permissionPolicyId String   @db.Uuid
  createdAt          DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionPolicy PermissionPolicy @relation(fields: [permissionPolicyId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionPolicyId])
  @@map("user_permission_policies")
}
