{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "namedInputs": {
    "sharedGlobals": [
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/**/tsconfig*.json"
    ],
    "default": [
      "{projectRoot}/**/*",
      "!{projectRoot}/.nuxt/**/*",
      "!{projectRoot}/.output/**/*",
      "!{projectRoot}/dist/**/*",
      "!{projectRoot}/coverage/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/test/**/*",
      "!{projectRoot}/jest.config.ts"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/.output",
        "{projectRoot}/.nuxt"
      ]
    },
    "generate": {
      "cache": true,
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/dist",
        "{projectRoot}/.output"
      ]
    },
    "lint:check": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ]
    },
    "typecheck": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ]
    },
    "test": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ]
    },
    "test:cov": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ],
      "outputs": [
        "{projectRoot}/coverage"
      ]
    },
    "test:e2e": {
      "cache": true,
      "inputs": [
        "default",
        "^default"
      ]
    }
  },
  "analytics": false
}
