model User {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // fields
  email          String  @unique @db.VarChar(255)
  isMfaEnabled   Boolean @default(false) @db.Boolean
  mfaSecret      String? @db.VarChar(512)
  websocketToken String  @default("00000000") @db.VarChar(256)

  // relations
  preferences UserPreferences?
  profile     UserProfile?

  @@map("users")
}
