model RolePermissionPolicy {
  id                 String   @id @default(uuid()) @db.Uuid
  role               UserRole
  permissionPolicyId String   @db.Uuid
  createdAt          DateTime @default(now())

  permissionPolicy PermissionPolicy @relation(fields: [permissionPolicyId], references: [id], onDelete: Cascade)

  @@unique([role, permissionPolicyId])
  @@map("role_permission_policies")
}
