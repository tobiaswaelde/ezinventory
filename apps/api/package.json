  },
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm prisma:generate",
    "dev": "tsx watch src/main.ts",
    "build": "pnpm prisma:generate && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "node dist/main.js",
    "openapi:export": "tsx src/scripts/export-openapi.ts",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:db:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format"
  },
  "dependencies": {
    "@casl/ability": "^6.8.1",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.2",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@scalar/nestjs-api-reference": "1.1.9",
    "@simplewebauthn/server": "^13.3.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "envalid": "^8.1.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@ezinventory/eslint-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "prisma": "^7.7.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
