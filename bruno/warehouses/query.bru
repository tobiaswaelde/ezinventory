meta {
  name: query
  type: http
  seq: 1
}

get {
  url: {{host}}/api/v1/warehouses?include[members]=true&include[address]=true
  body: none
  auth: inherit
}

params:query {
  include[members]: true
  include[address]: true
  ~include[members][include][user]: true
}

settings {
  encodeUrl: true
  timeout: 0
}
