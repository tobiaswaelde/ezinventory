meta {
  name: signin
  type: http
  seq: 2
}

post {
  url: {{host}}/api/v1/auth/signin
  body: json
  auth: inherit
}

body:json {
  {
    "email": "{{email}}",
    "password": "{{password}}",
    "totp": "000000"
  }
}

script:post-response {
  bru.setEnvVar('token', res.body.token);
  bru.setEnvVar('userId', res.body.user.id);
  bru.setEnvVar('websocketToken', res.body.user.websocketToken);
}

settings {
  encodeUrl: true
  timeout: 0
}
